        "D": "textures/ui/calendar/D",
        "E": "textures/ui/calendar/E",
        "F": "textures/ui/calendar/F"
      },
      "geometry": {
        "default": "geometry.horse.v3",

        "speedometer_tens":"geometry.speed.ms_tens",
        "speedometer_ones":"geometry.speed.ms_ones",
        "speedometer_decimal":"geometry.speed.ms_decimal",
        "speedometer_tenths":"geometry.speed.ms_tenths",
        "speedometer_hundredths":"geometry.speed.ms_hundredths",
        "speedometer_thousandths":"geometry.speed.ms_thousandths",
        "speedometer_ms":"geometry.speed.ms_ms",
        //WIP
        "health_tens":"geometry.health.health_tens",
        "health_ones":"geometry.health.health_ones",
        "health_decimal":"geometry.health.health_decimal",
        "health_tenths":"geometry.health.health_tenths",

        "jump_ones":"geometry.jump.jump_ones",
        "jump_decimal":"geometry.jump.jump_decimal",
        "jump_tenths":"geometry.jump.jump_tenths",

        "speed_rank":"geometry.rank.speed_rank",
        "jump_rank":"geometry.rank.jump_rank",
        "health_rank":"geometry.rank.health_rank"

      },
      "animations": {
        "baby_transform": "animation.horse.v3.baby_transform",
        "walk": "animation.horse.v3.walk",
        "eat": "animation.horse.v3.eat",
        "rear": "animation.horse.v3.rear",
        "tail": "animation.horse.v3.tail",
        "look_at_player": "animation.horse.v3.look_at_player"
      },
      "scripts": {
        "initialize": [
          "variable.eat_anim = 0.0;",
          "variable.max_speed = 0;",
          "variable.max_jump_vel = 0;",
          "variable.jump_height = 0;",
          "variable.start_y = 0;",
          "variable.peak_y = 0;"
        ],
        "pre_animation": [
          "variable.armor_texture_slot = query.armor_texture_slot(4);",
          "variable.eat_anim = math.clamp(variable.eat_anim + (query.is_grazing ? ((1.0 - variable.eat_anim) * 0.4 + 0.05) : -variable.eat_anim * 0.4 - 0.05) * query.delta_time * 20.0, 0.0, 1.0);",
          "variable.head_x_rot = query.target_x_rotation + (query.modified_move_speed > 0.2 ? (math.cos(query.modified_distance_moved * 11.46) * 11.46 * query.modified_move_speed + query.modified_move_speed * 11.46) : 0.0);",
          "variable.inverse_max_stand_eat = (1.0 - math.max(variable.stand_anim, variable.eat_anim));",
          "variable.leg_stand_factor = math.cos((query.modified_distance_moved * 38.38) + 180.0);",
          "variable.leg_x_rot_anim = variable.leg_stand_factor * 45.8 * query.modified_move_speed;",
          
// 1. Calculate current horizontal speed
"variable.horizontal_speed = math.max(0, query.ground_speed - math.abs(query.vertical_speed));",

// 2. The Sustain Timer
// If current speed > recorded max, count up. Otherwise, reset to 0.
"variable.speed_timer = (variable.horizontal_speed > variable.max_speed) ? (variable.speed_timer + 1) : 0;",

// 3. The Threshold Check (20 ticks / 1 second)
// Only update max_speed if the horse has maintained this new speed for 20 frames.
"variable.max_speed = (variable.speed_timer >= 20) ? variable.horizontal_speed : variable.max_speed;",

          // Watermark Vertical Speed and convert to estimated block height
          // 1. Lock the baseline Y when the horse is touching the ground
          "variable.start_y = query.is_on_ground ? query.position(1) : variable.start_y;",

          // 2. Track the peak Y only while in the air
          // If on ground, we reset peak_y to the current position to prepare for the next jump
          "variable.peak_y = !query.is_on_ground ? math.max(variable.peak_y, query.position(1)) : query.position(1);",

          // 3. Update the high score ONLY if the horse is in the air or just finished a jump
          // We use a small threshold (0.1) to ignore tiny bounces or step-ups
          "variable.jump_height = (!query.is_on_ground && (variable.peak_y - variable.start_y) > 0.1) ? math.max(variable.jump_height, variable.peak_y - variable.start_y) : variable.jump_height;",
          // Health logic (using vanilla query)
          "variable.h = query.max_health;"
        ],
        "animate": [
          {
            "baby_transform": "query.is_baby"
          },
          "walk",
          "look_at_player",
          {
            "rear": "variable.stand_anim > 0.0"
          },
          {
            "eat": "!query.is_standing"
          },
          {
            "tail": "variable.shake_tail"
          }
        ]
      },
      "render_controllers": [
        "controller.render.horse.v3",
        "controller.render.speed.tens",
        "controller.render.speed.ones",
        "controller.render.speed.decimal",
        "controller.render.speed.tenths",
        "controller.render.speed.hundredths",
        "controller.render.speed.thousandths",
        "controller.render.speed.ms_label",
        "controller.render.jump.ones",
        "controller.render.jump.decimal",
        "controller.render.jump.tenths",
        "controller.render.health.tens",
        "controller.render.health.ones",
        "controller.render.health.decimal",
        "controller.render.health.tenths",
        "controller.render.rank.speed",
        "controller.render.rank.jump",
        "controller.render.rank.health"
      ],
      "spawn_egg": {
        "texture": "spawn_egg_horse"
      }
    }
  }
