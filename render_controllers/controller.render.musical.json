{
  "format_version": "1.8.0",
  "render_controllers": {
    "controller.render.instrument.x_rot_negative": {
  "geometry": "Geometry.x_rot_negative",
  "materials": [{"*": "Material.calendar"}],
  "textures": ["variable.is_negative ? Texture.x_rot_negative : Texture.none"]
},

    "controller.render.instrument.x_rot_tens": {
      "geometry": "Geometry.x_rot_tens",
      "materials": [{"*": "Material.calendar"}],
      "textures": ["Array.digits[math.floor(math.abs(variable.pitch) / 10)]"],
      "arrays": {
        "textures": {
          "Array.digits": [
            "Texture.digit_0", "Texture.digit_1", "Texture.digit_2", "Texture.digit_3", "Texture.digit_4",
            "Texture.digit_5", "Texture.digit_6", "Texture.digit_7", "Texture.digit_8", "Texture.digit_9"
          ]
        }
      }
    },

    "controller.render.instrument.x_rot_ones": {
      "geometry": "Geometry.x_rot_ones",
      "materials": [{"*": "Material.calendar"}],
      "textures": ["Array.digits[math.mod(math.floor(math.abs(variable.pitch)), 10)]"],
      "arrays": {
        "textures": {
          "Array.digits": [
            "Texture.digit_0", "Texture.digit_1", "Texture.digit_2", "Texture.digit_3", "Texture.digit_4",
            "Texture.digit_5", "Texture.digit_6", "Texture.digit_7", "Texture.digit_8", "Texture.digit_9"
          ]
        }
      }
    },

    "controller.render.instrument.x_rot_dot": {
      "geometry": "Geometry.x_rot_dot",
      "materials": [{"*": "Material.calendar"}],
      "textures": ["Texture.dot"]
    },

    "controller.render.instrument.x_rot_tenths": {
      "geometry": "Geometry.x_rot_tenths",
      "materials": [{"*": "Material.calendar"}],
      "textures": ["Array.digits[math.mod(math.floor(math.abs(variable.pitch) * 10), 10)]"],
      "arrays": {
        "textures": {
          "Array.digits": [
            "Texture.digit_0", "Texture.digit_1", "Texture.digit_2", "Texture.digit_3", "Texture.digit_4",
            "Texture.digit_5", "Texture.digit_6", "Texture.digit_7", "Texture.digit_8", "Texture.digit_9"
          ]
        }
      }
    },

    "controller.render.instrument.x_rot_hundredths": {
      "geometry": "Geometry.x_rot_hundredths",
      "materials": [{"*": "Material.calendar"}],
      "textures": ["Array.digits[math.mod(math.floor(math.abs(variable.pitch) * 100), 10)]"],
      "arrays": {
        "textures": {
          "Array.digits": [
            "Texture.digit_0", "Texture.digit_1", "Texture.digit_2", "Texture.digit_3", "Texture.digit_4",
            "Texture.digit_5", "Texture.digit_6", "Texture.digit_7", "Texture.digit_8", "Texture.digit_9"
          ]
        }
      }
    },

    "controller.render.instrument.x_rot_thousandths": {
      "geometry": "Geometry.x_rot_thousandths",
      "materials": [{"*": "Material.calendar"}],
      "textures": ["Array.digits[math.mod(math.floor(math.abs(variable.pitch) * 1000), 10)]"],
      "arrays": {
        "textures": {
          "Array.digits": [
            "Texture.digit_0", "Texture.digit_1", "Texture.digit_2", "Texture.digit_3", "Texture.digit_4",
            "Texture.digit_5", "Texture.digit_6", "Texture.digit_7", "Texture.digit_8", "Texture.digit_9"
          ]
        }
      }
    }
  }
}